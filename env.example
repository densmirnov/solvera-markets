# Shared secrets and operator defaults.
# Keep real secrets in `.env`, then layer one network profile on top:
#   set -a; source .env; source .env.base; set +a
#   set -a; source .env; source .env.base-sepolia; set +a
#   set -a; source .env; source .env.status-sepolia; set +a

# Shared secrets
DEPLOYER_PRIVATE_KEY=hex_private_key
STATUS_DEPLOYER_PRIVATE_KEY=hex_private_key
BASE_DEPLOYER_PRIVATE_KEY=hex_private_key
ETHERSCAN_API_KEY=etherscan_key
DOKPLOY_API_KEY=dokploy_key
WRITE_API_KEY=change_me

# Generic active-network values
NETWORK_NAME=status-sepolia
CHAIN_ID=1660990954
RPC_URL=https://public.sepolia.rpc.status.network
EXPLORER_BASE_URL=https://sepoliascan.status.network
DEPLOYER_ADDRESS=0xc9EF33216b7EDa860Fd1F6CC991cc51257dC532d
CONTRACT_ADDRESS=0xF79367dAB12D8E12146685dA2830f112F02De71a
SUBGRAPH_URL=http://localhost:8000/subgraphs/name/intent/marketplace
BASE_SUBGRAPH_URL=https://api.studio.thegraph.com/query/17884/solvera/version/latest
STATUS_SUBGRAPH_URL=http://graph-node:8000/subgraphs/name/intent/status-marketplace

# Compatibility aliases for current Base-oriented tooling
BASE_NETWORK_NAME=base
BASE_CHAIN_ID=8453
BASE_CONTRACT_ADDRESS=0x442D68de43B37a0B2F975dc8dEfEfC349070Fb3A
BASE_RPC_URL=https://base-mainnet.example
BASE_SEPOLIA_RPC_URL=https://base-sepolia.example
STATUS_NETWORK_NAME=status-sepolia
STATUS_CHAIN_ID=1660990954
STATUS_SEPOLIA_RPC_URL=https://public.sepolia.rpc.status.network
STATUS_DEPLOYER_ADDRESS=0xc9EF33216b7EDa860Fd1F6CC991cc51257dC532d
STATUS_RPC_URL=https://public.sepolia.rpc.status.network

# Backend API
PORT=3000
SUBGRAPH_CACHE_TTL_MS=5000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
WRITE_AUTH_ENABLED=false
FEE_BPS_ON_ACCEPT=50
FIXED_FEE_ON_EXPIRE=1000000
BOND_BPS_OF_REWARD=500
BOND_MIN=1000000

# Frontend
VITE_API_BASE=https://solvera.markets/api
VITE_BASE_API_BASE=https://solvera.markets/api/base
VITE_STATUS_API_BASE=https://solvera.markets/api/status
VITE_BASE_RPC_URL=https://mainnet.base.org
VITE_STATUS_SEPOLIA_RPC_URL=https://public.sepolia.rpc.status.network
VITE_BASE_CONTRACT_ADDRESS=0x442D68de43B37a0B2F975dc8dEfEfC349070Fb3A
VITE_STATUS_CONTRACT_ADDRESS=0xF79367dAB12D8E12146685dA2830f112F02De71a

# Indexer (Graph)
GRAPH_NODE_URL=http://localhost:8020
GRAPH_IPFS_URL=http://localhost:5001
CORS_ORIGIN=https://solvera.markets

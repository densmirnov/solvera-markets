FROM node:20-alpine AS builder

WORKDIR /app

COPY package.json package-lock.json* tsconfig.json vite.config.ts eslint.config.js postcss.config.js index.html SKILL.md ./
COPY public ./public
COPY src ./src

ARG VITE_API_BASE
ARG VITE_BASE_API_BASE
ARG VITE_STATUS_API_BASE
ARG VITE_BASE_RPC_URL
ARG VITE_STATUS_SEPOLIA_RPC_URL
ARG VITE_BASE_CONTRACT_ADDRESS
ARG VITE_STATUS_CONTRACT_ADDRESS
ENV VITE_API_BASE=${VITE_API_BASE}
ENV VITE_BASE_API_BASE=${VITE_BASE_API_BASE}
ENV VITE_STATUS_API_BASE=${VITE_STATUS_API_BASE}
ENV VITE_BASE_RPC_URL=${VITE_BASE_RPC_URL}
ENV VITE_STATUS_SEPOLIA_RPC_URL=${VITE_STATUS_SEPOLIA_RPC_URL}
ENV VITE_BASE_CONTRACT_ADDRESS=${VITE_BASE_CONTRACT_ADDRESS}
ENV VITE_STATUS_CONTRACT_ADDRESS=${VITE_STATUS_CONTRACT_ADDRESS}

RUN npm install
RUN npm run build

FROM nginx:1.27-alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
